# Stratum configuration — copy to .env and fill in the two secrets.
#
# Generate strong values:
#   openssl rand -base64 48    # JWT_SECRET
#   openssl rand -hex 32       # ENCRYPTION_KEY  (AES-256 secrets vault key)
JWT_SECRET=
ENCRYPTION_KEY=

# Public base URL of this instance (used in agent install one-liners and links).
BASE_URL=http://localhost:8080

# Host port the UI is published on (the container listens on 80 internally).
STRATUM_PORT=8080

# Image tag to run. Pin to a release (e.g. v0.1.0) in production; default latest.
STRATUM_TAG=latest

# Optional: absolute path to a host `trivy` binary for image CVE scanning.
# The published backend image is slim and ships without Trivy.
# TRIVY_PATH=/usr/local/bin/trivy

# Optional: bearer token required to scrape GET /metrics. When unset, /metrics
# is reachable only from loopback (same-host Prometheus / SSH tunnel). Set this
# to scrape from a remote Prometheus (scrape config: bearer_token: <value>).
#   openssl rand -hex 32
# STRATUM_METRICS_TOKEN=
