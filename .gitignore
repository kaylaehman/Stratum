# ─── Secrets & local config (NEVER commit) ───────────────────────────────
.env
.env.*
!.env.example
*.local
# Stratum runtime data dir (SQLite DB, agent CA, snapshots)
/data/
data/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
# Agent / TLS material
*.pem
*.key
*.crt
*.csr
!**/testdata/**/*.pem
!**/testdata/**/*.crt

# ─── Go (backend, agent) ──────────────────────────────────────────────────
# Compiled binaries / build output
/bin/
/backend/bin/
/agent/bin/
/agent/agent
/agent/stratum-agent
/backend/stratum
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# Go workspace cache / vendor (vendor only if you choose to vendor)
go.work.sum
# Coverage
coverage.out
coverage.html
*.cover

# ─── Frontend (Vite + React + TS) ─────────────────────────────────────────
node_modules/
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/coverage/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Proto / codegen (generated Go IS committed; keep buf cache out) ───────
.buf-cache/

# ─── Docker / compose local overrides ─────────────────────────────────────
docker-compose.override.yml

# ─── Logs ─────────────────────────────────────────────────────────────────
# `/logs/` (not bare `logs/`) — bare pattern matches any `logs/` directory in
# the tree, including source dirs like `frontend/src/components/logs/`.
*.log
/logs/

# ─── OS cruft ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── Editors / IDEs ───────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
*~

# ─── Temp ─────────────────────────────────────────────────────────────────
tmp/
*.tmp

# ─── Local-only (kept out of version control) ─────────────────────────────
# Per maintainer decision: these live locally, not committed to the repo.
/CLAUDE.md
/FEATURES.md
/DESIGN.md
skills-lock.json
# Internal sub-project design specs — local-only, never committed
docs/superpowers/specs/
**/superpowers/specs/


# Agent worktrees (live, per-session; never commit)
.claude/worktrees/

# Ruflo / claude-flow agent scratch artifacts
.claude-flow/
.swarm/
.hive-mind/
ruvector.db
