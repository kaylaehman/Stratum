#!/bin/sh
# Stratum agent installer for node {{.NodeID}} — generated by the Stratum backend.
# Runs as root: creates a non-root 'stratum-agent' user, enrolls via CSR (the
# private key never leaves this host), and installs a hardened systemd service.
set -eu

if [ "$(id -u)" != "0" ]; then
  echo "error: run this as root, e.g.  sudo sh $0" >&2
  exit 1
fi

BASE_URL="{{.BaseURL}}"
NODE_ID="{{.NodeID}}"
TOKEN="{{.Token}}"

for tool in curl openssl install useradd sha256sum systemctl mktemp; do
  command -v "$tool" >/dev/null 2>&1 || { echo "error: required tool not found: $tool" >&2; exit 1; }
done

case "$(uname -m)" in
  x86_64|amd64)  ARCH="amd64"; SHA="{{.SHA256Amd64}}" ;;
  aarch64|arm64) ARCH="arm64"; SHA="{{.SHA256Arm64}}" ;;
  *) echo "error: unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT
umask 077

echo "==> downloading agent ($ARCH)"
# HTTPS only, no redirect-following, TLS verification never disabled. Verify first.
curl -fsS --proto '=https' -H "Authorization: Bearer $TOKEN" \
  "$BASE_URL/api/nodes/$NODE_ID/agent/binary?arch=$ARCH" -o "$TMP/agent"

echo "==> verifying checksum"
echo "$SHA  $TMP/agent" | sha256sum -c - >/dev/null 2>&1 \
  || { echo "error: agent binary checksum mismatch — aborting" >&2; exit 1; }

echo "==> creating non-root stratum-agent user"
id stratum-agent >/dev/null 2>&1 \
  || useradd --system --no-create-home --shell /usr/sbin/nologin stratum-agent

echo "==> generating key + CSR (private key stays on this host)"
openssl ecparam -name prime256v1 -genkey -noout -out "$TMP/agent.key"
openssl req -new -key "$TMP/agent.key" -subj "/CN=stratum-agent" -out "$TMP/agent.csr"

echo "==> enrolling (submitting CSR for signing)"
curl -fsS --proto '=https' -H "Authorization: Bearer $TOKEN" \
  --data-binary "@$TMP/agent.csr" \
  "$BASE_URL/api/nodes/$NODE_ID/agent/enroll" -o "$TMP/agent.crt"

echo "==> installing binary + certs"
install -m 0755 -o root -g root "$TMP/agent" /usr/local/bin/stratum-agent

cat > "$TMP/ca.crt" <<'STRATUM_CA_EOF'
{{.CACert}}
STRATUM_CA_EOF

install -d -m 0750 -o root -g stratum-agent /etc/stratum-agent
install -m 0640 -o root         -g stratum-agent "$TMP/ca.crt"    /etc/stratum-agent/ca.crt
install -m 0644 -o root         -g stratum-agent "$TMP/agent.crt" /etc/stratum-agent/agent.crt
install -m 0600 -o stratum-agent -g stratum-agent "$TMP/agent.key" /etc/stratum-agent/agent.key

cat > "$TMP/config.yaml" <<CFG_EOF
server_url: "{{.BaseURL}}"
listen_addr: "{{.ListenAddr}}"
tls:
  cert_file: /etc/stratum-agent/agent.crt
  key_file: /etc/stratum-agent/agent.key
  ca_file: /etc/stratum-agent/ca.crt
CFG_EOF
install -m 0640 -o root -g stratum-agent "$TMP/config.yaml" /etc/stratum-agent/config.yaml

cat > /etc/systemd/system/stratum-agent.service <<'UNIT_EOF'
[Unit]
Description=Stratum Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/stratum-agent -config /etc/stratum-agent/config.yaml
User=stratum-agent
Group=stratum-agent
Restart=on-failure
RestartSec=5
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
RestrictNamespaces=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
CapabilityBoundingSet=
AmbientCapabilities=
UMask=0077
ReadOnlyPaths=/etc/stratum-agent

[Install]
WantedBy=multi-user.target
UNIT_EOF

echo "==> starting service"
systemctl daemon-reload
systemctl enable --now stratum-agent
echo "Stratum agent installed and started for node $NODE_ID."
